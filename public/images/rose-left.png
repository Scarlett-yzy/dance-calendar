<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 340 340">
  <g transform="translate(170,170)">
    <!-- 外层花瓣 -->
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(0)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(30)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(60)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(90)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(120)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(150)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(180)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(210)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(240)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(270)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(300)"/>
    <ellipse cx="0" cy="-60" rx="25" ry="45" fill="#e8b4b8" opacity="0.7" transform="rotate(330)"/>
    <!-- 内层花瓣 -->
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(15)"/>
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(75)"/>
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(135)"/>
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(195)"/>
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(255)"/>
    <ellipse cx="0" cy="-40" rx="18" ry="32" fill="#f2c9cc" opacity="0.85" transform="rotate(315)"/>
    <!-- 花蕊 -->
    <circle cx="0" cy="0" r="14" fill="#f5deb3" opacity="0.9"/>
    <circle cx="0" cy="0" r="8" fill="#e8c87a" opacity="0.8"/>
    <circle cx="-4" cy="-4" r="3" fill="#d4a853" opacity="0.6"/>
    <circle cx="4" cy="2" r="2.5" fill="#d4a853" opacity="0.6"/>
    <circle cx="-2" cy="5" r="2" fill="#d4a853" opacity="0.6"/>
  </g>
</svg>